{
  "version": 2,
  "buildCommand": null,
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/webhook", "destination": "/api/webhook" },
    { "source": "/privacy", "destination": "/api/privacy" }
  ],
  "functions": {
    "api/webhook.ts": {
      "maxDuration": 30
    },
    "api/cron/check-filters.ts": {
      "maxDuration": 60
    },
    "api/cron/ping.ts": {
      "maxDuration": 5
    }
  },
  "crons": [
    {
      "path": "/api/cron/check-filters",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/ping",
      "schedule": "*/10 * * * *"
    }
  ]
}